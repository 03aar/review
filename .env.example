# Database - Use file:./reviewforge.db for local dev, or a Turso URL for production
DATABASE_URL=file:./reviewforge.db
# DATABASE_AUTH_TOKEN=  # Required for Turso/LibSQL cloud

# Auth (better-auth)
BETTER_AUTH_SECRET=your-secret-here-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# App URL (embedded at build time for client-side auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
